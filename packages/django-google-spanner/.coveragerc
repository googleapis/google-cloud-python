[run]
branch = True
source =
    django_spanner
[paths]
source =
    django_spanner
    */site-packages/django_spanner

[paths]
source =
    django_spanner
    */site-packages/django_spanner

[report]
fail_under = 68
show_missing = True
exclude_lines =
    # Re-enable the standard pragma
    pragma: NO COVER
    # Ignore debug-only repr
    def __repr__
    # Ignore abstract methods
    raise NotImplementedError
omit =
  tests/*
  */tests/*